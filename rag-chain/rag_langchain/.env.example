# 复制本文件为 .env,填入你的 key: cp .env.example .env

# DashScope API key(必填)
# 申请地址: https://dashscope.console.aliyuncs.com/apiKey
DASHSCOPE_API_KEY=sk-your-key-here

# LLM 模型与参数
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Embedding 模型
EMBEDDING_MODEL=BAAI/bge-m3

# 向量库存储目录
CHROMA_PERSIST_DIR=./chroma_data

# 文本切分参数
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# 检索参数
RETRIEVAL_K=10
RERANK_TOP_N=5

# 缓存配置
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379
CACHE_TTL_RESULT=300
CACHE_TTL_RETRIEVAL=1800
CACHE_TTL_EMBEDDING=86400

# 并发配置
MAX_CONCURRENT_REQUESTS=50
LLM_POOL_SIZE=10
